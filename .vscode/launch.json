{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run JPLMM Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/dist/**/*.js",
        "${workspaceFolder}/packages/vscode-extension/dist/**/*.cjs"
      ],
      "preLaunchTask": "build:jplmm-vscode-extension"
    }
  ]
}
