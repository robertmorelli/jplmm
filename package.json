{
  "name": "jplmm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "bench:research": "node_modules/vitest/vitest.mjs run -c vitest.research.config.ts",
    "bench:dafny": "node_modules/vitest/vitest.mjs run -c vitest.dafny.config.ts",
    "bench:examples-dafny": "node_modules/vitest/vitest.mjs run -c vitest.examples-dafny.config.ts",
    "bench:examples-dafny-comparable": "node_modules/vitest/vitest.mjs run -c vitest.examples-dafny-comparable.config.ts",
    "bench:compare": "node tools/bench-compare.mjs",
    "examples:regen": "node tools/generate_examples.mjs",
    "examples:dafny:regen": "node tools/generate_examples_dafny.mjs",
    "examples:dafny:bv32:regen": "node tools/generate_examples_dafny_bv32.mjs",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.17.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.5"
  }
}
